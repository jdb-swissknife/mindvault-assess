# MindVault AI Assessment Pipeline
# Copy this file to .env and fill in your values

# Anthropic/Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-3-7-sonnet-20250219

# Retell.ai Webhook Settings
RETELL_WEBHOOK_SECRET=whsec_xxxxx

# Output Directory
REPORTS_DIR=/root/projects/mindvault-assess/reports

# Server Settings
PORT=8000
HOST=0.0.0.0

# Optional: Email Notifications
SEND_EMAIL_ON_COMPLETE=false
EMAIL_FROM=apply@mindvaultstudio.net
# SMTP Settings (if using email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
